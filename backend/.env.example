# Tecsior CRM — backend (copy to .env and fill in)
MONGODB_URI="mongodb+srv://USER:PASS@cluster0.example.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="tecsior"

JWT_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
JWT_EXPIRES_IN="7d"

PORT=7011
NODE_ENV=development
CORS_ORIGIN="http://localhost:7010"
COOKIE_NAME="tecsior_session"

# Cloudinary — cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL="cloudinary://KEY:SECRET@CLOUD_NAME"
CLOUDINARY_FOLDER="tecsior"
UPLOAD_MAX_BYTES=10485760
